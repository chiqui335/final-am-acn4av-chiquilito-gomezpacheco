<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/darkCyanBackground">

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="85dp"
        android:layout_height="85dp"
        android:layout_marginTop="7dp"
        android:contentDescription="@string/minilogo_app"
        android:src="@drawable/logo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Volver"
        android:src="@drawable/baseline_arrow_back_24"
        app:layout_constraintBottom_toBottomOf="@id/imgLogo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/imgLogo" />

    <TextView
        android:id="@+id/txtPassword"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="30dp"
        android:gravity="center"
        android:padding="10dp"
        android:text="Aquí aparecerá la contraseña"
        android:textColor="@color/TextHint"
        android:textSize="24sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgLogo" />

    <!-- Nombre -->
    <EditText
        android:id="@+id/etNombreClave"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="18dp"
        android:background="@drawable/edittext_underline"
        android:hint="Nombre de la contraseña"
        android:inputType="textPersonName"
        android:padding="10dp"
        android:textColor="@color/TextHint"
        android:textColorHint="@color/TextHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtPassword" />

    <!-- Modo -->
    <TextView
        android:id="@+id/txtModo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="14dp"
        android:text="Modo de generación:"
        android:textColor="@color/TextHint"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etNombreClave" />

    <RadioGroup
        android:id="@+id/rgModo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtModo">

        <RadioButton
            android:id="@+id/rbPassword"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="@color/yellow"
            android:checked="true"
            android:text="Contraseña"
            android:textColor="@color/TextHint" />

        <RadioButton
            android:id="@+id/rbPassphrase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="18dp"
            android:buttonTint="@color/yellow"
            android:text="Passphrase"
            android:textColor="@color/TextHint" />
    </RadioGroup>

        <LinearLayout
        android:id="@+id/panelOpciones"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/rgModo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Panel: Password -->
        <LinearLayout
            android:id="@+id/panelPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Longitud:"
                android:textColor="@color/TextHint"
                android:textSize="16sp" />

            <SeekBar
                android:id="@+id/seekBarLongitud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                android:max="12"
                android:progress="4"
                android:progressTint="@color/yellow"
                android:thumbTint="@color/yellow" />

            <TextView
                android:id="@+id/txtLongitud"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="12 caracteres"
                android:textColor="@color/TextHint"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/checkEspeciales"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:buttonTint="@color/yellow"
                android:text="Incluir caracteres especiales"
                android:textColor="@color/TextHint"
                android:textSize="15sp" />
        </LinearLayout>

        <!-- Panel: Passphrase -->
        <LinearLayout
            android:id="@+id/panelPassphrase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cantidad de palabras:"
                android:textColor="@color/TextHint"
                android:textSize="16sp" />

            <SeekBar
                android:id="@+id/seekBarPalabras"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/white"
                android:max="6"
                android:progress="2"
                android:progressTint="@color/yellow"
                android:thumbTint="@color/yellow" />

            <TextView
                android:id="@+id/txtPalabras"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="4 palabras"
                android:textColor="@color/TextHint"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/checkGuiones"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:buttonTint="@color/yellow"
                android:text="Separar con guiones"
                android:textColor="@color/TextHint"
                android:textSize="15sp" />

            <CheckBox
                android:id="@+id/checkCapitalizar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:buttonTint="@color/yellow"
                android:text="Capitalizar palabras"
                android:textColor="@color/TextHint"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnGenerar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:backgroundTint="@color/yellow"
        android:text="GENERAR"
        android:textColor="@color/TextButton1"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/panelOpciones"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Acciones finales -->
    <LinearLayout
        android:id="@+id/ButtonsMain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/btnGenerar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnCopiar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#358E2F"
            android:text="COPIAR"
            android:textColor="@color/TextHint" />

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:backgroundTint="@android:color/holo_blue_light"
            android:text="GUARDAR"
            android:textColor="@color/TextHint" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>